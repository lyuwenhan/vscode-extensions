{
	"name": "mermaid-snap",
	"displayName": "Mermaid Snap",
	"private": false,
	"version": "1.0.19",
	"publisher": "lyuwenhan",
	"description": "A VS Code extension that lets you preview Mermaid diagrams.",
	"engines": {
		"vscode": "^1.80.0"
	},
	"main": "./out/extension.js",
	"activationEvents": [
		"onStartupFinished"
	],
	"icon": "media/icon.png",
	"scripts": {
		"vscode:prepublish": "node build.js",
		"package": "vsce package"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lyuwenhan/vscode-extensions",
		"directory": "mermaid-snap"
	},
	"bugs": {
		"url": "https://github.com/lyuwenhan/vscode-extensions/issues"
	},
	"homepage": "https://lyuwenhan.github.io",
	"categories": [
		"Visualization",
		"Other"
	],
	"keywords": [
		"chart",
		"class diagram",
		"diagram preview",
		"diagram",
		"editor",
		"er diagram",
		"export",
		"extension",
		"flowchart",
		"gantt",
		"graph",
		"journey",
		"live preview",
		"markdown preview",
		"markdown",
		"mermaid diagram",
		"mermaid",
		"open-vsx",
		"openvsx",
		"pie chart",
		"png",
		"preview",
		"render",
		"sequence diagram",
		"state diagram",
		"svg",
		"visual studio code",
		"visualization",
		"vscode"
	],
	"dependencies": {
		"@resvg/resvg-js": "^2.6.2"
	},
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "preview",
					"title": "Mermaid Preview",
					"icon": "media/icon.svg"
				}
			]
		},
		"views": {
			"preview": [
				{
					"type": "webview",
					"id": "mmdPreview",
					"name": "Mermaid Preview",
					"icon": "media/icon.svg"
				}
			]
		}
	}
}
