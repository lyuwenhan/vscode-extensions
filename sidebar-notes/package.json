{
	"name": "sidebar-notes",
	"displayName": "Sidebar Notes",
	"private": false,
	"version": "1.0.23",
	"publisher": "lyuwenhan",
	"description": "A VS Code extension for taking quick notes in the sidebar.",
	"engines": {
		"vscode": "^1.80.0"
	},
	"main": "./out/extension.js",
	"activationEvents": [
		"onStartupFinished"
	],
	"icon": "media/icon.png",
	"scripts": {
		"vscode:prepublish": "node build.js",
		"package": "vsce package"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lyuwenhan/vscode-extensions",
		"directory": "sidebar-notes"
	},
	"bugs": {
		"url": "https://github.com/lyuwenhan/vscode-extensions/issues"
	},
	"homepage": "https://lyuwenhan.github.io",
	"categories": [
		"Other"
	],
	"keywords": [
		"editor notes",
		"extension",
		"journal",
		"memo",
		"note taking",
		"notepad",
		"notes",
		"open-vsx",
		"openvsx",
		"organizer",
		"panel",
		"productivity",
		"quick note",
		"quick notes",
		"scratchpad",
		"side panel",
		"sidebar notes",
		"sidebar",
		"sticky notes",
		"text editor",
		"todo",
		"tool",
		"utilities",
		"utility",
		"visual studio code",
		"vscode",
		"workspace notes"
	],
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "sidebarNotes",
					"title": "Notes",
					"icon": "media/icon.svg"
				}
			]
		},
		"views": {
			"sidebarNotes": [
				{
					"type": "webview",
					"id": "notesView",
					"name": "Notes",
					"icon": "media/icon.svg"
				}
			]
		},
		"configuration": {
			"title": "Sidebar Notes",
			"properties": {
				"sidebarNotes.theme": {
					"type": "string",
					"enum": [
						"auto",
						"light",
						"dim",
						"dark"
					],
					"enumDescriptions": [
						"Follow the current VS Code color theme.",
						"Use the light color scheme.",
						"Use the dim (muted dark) color scheme.",
						"Use the dark color scheme."
					],
					"default": "auto",
					"description": "Color theme for the Sidebar Notes panel."
				}
			}
		},
		"commands": [
			{
				"command": "sidebarNotes.switchTheme",
				"title": "Switch Theme",
				"category": "Sidebar Notes"
			}
		]
	}
}
